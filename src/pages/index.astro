---
// src/pages/index.astro — solo importa y ordena componentes (doc §6).
// Sin copy ni estilos. El orden define el orden visual de la landing.
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ValueProps from '../components/ValueProps.astro';
import Story from '../components/Story.astro';
import BuyerReviews from '../components/BuyerReviews.astro';
import Inspiration from '../components/Inspiration.astro';
import Benefits from '../components/Benefits.astro';
import SocialReviews from '../components/SocialReviews.astro';
import Showcase from '../components/Showcase.astro';
import FinalCta from '../components/FinalCta.astro';
import Ratings from '../components/Ratings.astro';
import Testimonials from '../components/Testimonials.astro';
import About from '../components/About.astro';
import Closing from '../components/Closing.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout>
  <main id="main" class="min-h-screen font-sans">
    <Hero />
    <ValueProps />
    <Story />
    <BuyerReviews />
    <Inspiration />
    <Benefits />
    <SocialReviews />
    <Showcase />
    <FinalCta />
    <Ratings />
    <Testimonials />
    <About />
    <Closing />
  </main>
  <Footer />
  <ScrollReveal />
</Layout>
