---
// Sección 12 — "Iets meer over mij..." (doc §8). Bio de la autora + retrato + CTA.
import { Image } from 'astro:assets';
import portrait from '../assets/about.webp';
import { copy } from '../lib/copy.js';
import { CHECKOUT } from '../lib/checkout.js';
import CheckoutButton from './CheckoutButton.astro';
const { about, inspiration } = copy;
---

<section
  aria-labelledby="about-heading"
  class="bg-slow-cream py-16 sm:py-24"
>
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 sm:px-8 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
    {/* retrato */}
    <div class="reveal relative mx-auto w-full max-w-[360px]">
      <div class="overflow-hidden rounded-[1.8rem] shadow-frame ring-1 ring-slow-ink/5">
        <Image
          src={portrait}
          alt={about.imageAlt}
          widths={[360, 540, 720]}
          sizes="(min-width:1024px) 380px, 82vw"
          formats={['avif', 'webp']}
          quality={84}
          loading="lazy"
          class="aspect-[4/5] h-full w-full object-cover"
        />
      </div>
      <div class="absolute -bottom-4 left-6 rounded-2xl bg-white px-5 py-3 shadow-card">
        <p class="text-[13px] font-black text-slow-ink">{about.name}</p>
      </div>
    </div>

    {/* texto */}
    <div class="reveal">
      <h2 id="about-heading" class="mt-3 text-3xl font-black tracking-tight text-slow-ink sm:text-[2.5rem]">
        {about.heading}
      </h2>
      <p class="mt-4 text-[18px] font-bold text-slow-forest-dark">{about.intro}</p>
      <div class="mt-3 space-y-3 text-[15.5px] leading-relaxed text-slow-ink-soft">
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="mt-7 sm:max-w-md">
        <CheckoutButton
          href={CHECKOUT.ebooks}
          label={about.cta}
          price={inspiration.price}
          variant="primary"
          block={true}
        />
      </div>
    </div>
  </div>
</section>
