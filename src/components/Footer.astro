---
// Sección 14 — Footer (doc §8). 100% estático. Copy de copy.footer.
import { copy } from '../lib/copy.js';
import Icon from './Icon.astro';
const { footer } = copy;
---

<footer class="border-t border-slow-cream-deep bg-slow-cream">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
      <div>
        <div class="flex items-center gap-2.5">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-slow-terracotta text-white">
            <Icon name="pot" class="h-6 w-6" />
          </span>
          <div class="leading-tight">
            <p class="text-[16px] font-black text-slow-ink">{footer.brand}</p>
            <p class="text-[12px] font-semibold text-slow-moss">{footer.author}</p>
          </div>
        </div>
        <p class="mt-4 max-w-md text-[13.5px] leading-relaxed text-slow-ink-soft">{footer.tagline}</p>
      </div>

      <nav aria-label={copy.a11y.footerNav} class="flex flex-wrap gap-x-6 gap-y-2">
        {
          footer.links.map((l) => (
            <a
              href={l.href}
              class="text-[13.5px] font-semibold text-slow-ink-soft underline-offset-4 hover:text-slow-terracotta hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slow-forest/40"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-8 border-t border-slow-cream-deep pt-6">
      <p class="text-[12.5px] text-slow-moss">{footer.copyright}</p>
    </div>
  </div>
</footer>
