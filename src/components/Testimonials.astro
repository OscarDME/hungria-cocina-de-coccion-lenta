---
// Sección 11 — "Dit zeggen anderen over mijn recepten" (doc §8). 3 testimonios
// destacados + CTA. Copy de copy.testimonials.
import { copy } from '../lib/copy.js';
import { CHECKOUT } from '../lib/checkout.js';
import CheckoutButton from './CheckoutButton.astro';
import StarRating from './StarRating.astro';
import Icon from './Icon.astro';
const { testimonials, inspiration } = copy;
---

<section
  aria-labelledby="testimonials-heading"
  class="bg-slow-sage/60 py-16 sm:py-24"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <h2
      id="testimonials-heading"
      class="reveal mx-auto max-w-3xl text-balance text-center text-3xl font-black tracking-tight text-slow-ink sm:text-[2.5rem]"
    >
      {testimonials.heading}
    </h2>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        testimonials.items.map((t, i) => (
          <figure
            class="reveal flex h-full flex-col rounded-3xl bg-white p-7 shadow-card ring-1 ring-slow-cream-deep"
            style={`transition-delay:${i * 90}ms`}
          >
            <Icon name="quote" class="h-8 w-8 text-slow-terracotta/70" />
            <h3 class="mt-3 text-[18px] font-black leading-snug text-slow-terracotta">{t.title}</h3>
            <blockquote class="mt-2 flex-1 text-[15px] leading-relaxed text-slow-ink-soft">
              {t.quote}
            </blockquote>
            <StarRating value={5} class="mt-4 h-5 w-5" />
          </figure>
        ))
      }
    </div>

    <div class="reveal mt-10 flex justify-center">
      <CheckoutButton
        href={CHECKOUT.hardcoverNL}
        label={testimonials.cta}
        price={inspiration.price}
        variant="primary"
      />
    </div>
  </div>
</section>
