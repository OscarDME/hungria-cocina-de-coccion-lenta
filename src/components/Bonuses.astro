---
// Sección de BONOS — refuerza la oferta con 5 bonos gratis (value stack).
// Todo el texto viene de copy.bonuses. Los iconos son fijos (no se traducen).
import { copy } from '../lib/copy.js';
import Icon from './Icon.astro';
const { bonuses } = copy;
const icons = ['clock', 'search', 'chef', 'pot', 'heart'];
---

<section
  aria-labelledby="bonuses-heading"
  class="bg-gradient-to-b from-slow-cream to-slow-sage/40 py-16 sm:py-24"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      {bonuses.eyebrow && (
        <span class="inline-flex items-center gap-2 rounded-full bg-slow-terracotta/12 px-4 py-1.5 text-[12px] font-black uppercase tracking-widest text-slow-terracotta">
          <Icon name="sparkle" class="h-4 w-4" /> {bonuses.eyebrow}
        </span>
      )}
      <h2
        id="bonuses-heading"
        class="mt-4 text-balance text-3xl font-black tracking-tight text-slow-ink sm:text-[2.5rem]"
      >
        {bonuses.heading}
      </h2>
      {bonuses.subheading && (
        <p class="mt-3 text-[16px] font-semibold text-slow-ink-soft">{bonuses.subheading}</p>
      )}
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        bonuses.items.map((it, i) => (
          <div
            class="reveal flex items-start gap-4 rounded-3xl border border-white bg-white/85 p-6 shadow-soft"
            style={`transition-delay:${(i % 2) * 90}ms`}
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-slow-forest text-white shadow-soft">
              <Icon name={icons[i] || 'sparkle'} class="h-6 w-6" />
            </span>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                {it.tag && (
                  <span class="rounded-full bg-slow-gold/20 px-2.5 py-0.5 text-[11px] font-black uppercase tracking-wide text-slow-forest-dark">
                    {it.tag}
                  </span>
                )}
                {it.value && (
                  <span class="text-[12.5px] font-bold text-slow-moss">
                    <s class="opacity-70">{it.value}</s>{' '}
                    <span class="text-slow-terracotta">{bonuses.freeWord}</span>
                  </span>
                )}
              </div>
              <h3 class="mt-1.5 text-[18px] font-extrabold text-slow-ink">{it.title}</h3>
              <p class="mt-1 text-[14.5px] leading-relaxed text-slow-ink-soft">{it.text}</p>
            </div>
          </div>
        ))
      }
    </div>

    {/* Callout de valor total */}
    <div class="reveal mx-auto mt-10 max-w-2xl rounded-3xl border-2 border-slow-terracotta/30 bg-white p-6 text-center shadow-card sm:p-8">
      <p class="text-[15px] font-semibold text-slow-ink-soft">
        {bonuses.totalLabel}: <s class="font-bold text-slow-moss">{bonuses.totalValue}</s>
      </p>
      <p class="mt-1 text-[20px] font-black text-slow-terracotta sm:text-[24px]">{bonuses.freeLine}</p>
    </div>
  </div>
</section>
