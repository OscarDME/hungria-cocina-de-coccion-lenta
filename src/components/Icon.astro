---
// Íconos como SVG inline (doc §8: 0 requests, 0 imágenes con texto).
// currentColor hereda el color del contenedor. Decorativos por defecto.
const { name, class: cls = 'w-6 h-6', title } = Astro.props;
const deco = title ? {} : { 'aria-hidden': 'true' };
const paths = {
  pot: '<path d="M4 10h16M6 10v6a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3v-6M9 10V7a3 3 0 0 1 6 0v3M3 13h1M20 13h1M8 5.5 7 4M16 5.5 17 4"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  chef: '<path d="M6 15h12v3a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-3Z"/><path d="M7 15a4 4 0 0 1-1-7.9A4.5 4.5 0 0 1 12 4a4.5 4.5 0 0 1 6 3.1A4 4 0 0 1 17 15"/>',
  check: '<path d="m20 6-11 11L4 12"/>',
  quote: '<path d="M7 7c-2.2 0-4 1.8-4 4v6h6v-6H5c0-1.1.9-2 2-2V7Zm10 0c-2.2 0-4 1.8-4 4v6h6v-6h-4c0-1.1.9-2 2-2V7Z"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  sparkle: '<path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 4 13c0-5 4.5-9 16-9 0 8-4 12-9 12Z"/><path d="M4 20c2-5 6-8 12-9"/>',
  heart: '<path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9Z"/>',
  bowl: '<path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M12 4c1.5 1 1.5 2.5 0 3.5"/><path d="M8 5c1 .7 1 1.7 0 2.5"/><path d="M16 5c1 .7 1 1.7 0 2.5"/><path d="M6 20h12"/>',
  stew: '<path d="M5 9h14l-1 8a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 9Z"/><path d="M3 9h18M9 6c0-1 1-1.5 1-2.5M15 6c0-1 1-1.5 1-2.5"/>',
  book: '<path d="M5 4h11a3 3 0 0 1 3 3v13H8a3 3 0 0 1-3-3V4Z"/><path d="M5 17a3 3 0 0 1 3-3h11"/><path d="M9 8h6M9 11h4"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  chat: '<path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.8A8 8 0 1 1 21 12Z"/>',
};
const star =
  '<path d="M12 3.2l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.3l1-5.8L3.5 9.4l5.9-.9L12 3.2Z"/>';
---
{
  name === 'star' ? (
    <svg viewBox="0 0 24 24" fill="currentColor" class={cls} {...deco} role={title ? 'img' : undefined}>
      {title && <title>{title}</title>}
      <Fragment set:html={star} />
    </svg>
  ) : (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={cls}
      {...deco}
      role={title ? 'img' : undefined}
    >
      {title && <title>{title}</title>}
      <Fragment set:html={paths[name] || ''} />
    </svg>
  )
}
