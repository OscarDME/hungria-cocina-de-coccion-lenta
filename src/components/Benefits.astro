---
// Sección 6 — "Jouw voordelen op een rijtje" + categorías de recetas (doc §8).
import { copy } from '../lib/copy.js';
import Icon from './Icon.astro';
const { benefits } = copy;
const catIcons = ['stew', 'bowl', 'chef'];
---

<section
  aria-labelledby="benefits-heading"
  class="bg-slow-sage/60 py-16 sm:py-24"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2
        id="benefits-heading"
        class="mt-3 text-balance text-3xl font-black tracking-tight text-slow-ink sm:text-[2.5rem]"
      >
        {benefits.heading}
      </h2>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        benefits.items.map((it, i) => (
          <div
            class="reveal flex items-start gap-4 rounded-3xl border border-white bg-white/80 p-6 shadow-soft"
            style={`transition-delay:${(i % 2) * 90}ms`}
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-slow-forest text-white shadow-soft">
              <Icon name="check" class="h-6 w-6" />
            </span>
            <div>
              <h3 class="text-[18px] font-extrabold text-slow-ink">{it.title}</h3>
              <p class="mt-1 text-[14.5px] leading-relaxed text-slow-ink-soft">{it.text}</p>
            </div>
          </div>
        ))
      }
    </div>

    {/* Categorías de recetas */}
    <div class="reveal mt-12">
      <div class="grid gap-4 sm:grid-cols-3">
        {
          benefits.categories.map((c, i) => (
            <div class="flex items-center gap-3 rounded-2xl bg-white/70 p-5 text-left shadow-soft ring-1 ring-slow-sage-deep/60">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-slow-terracotta/12 text-slow-terracotta">
                <Icon name={catIcons[i] || 'bowl'} class="h-6 w-6" />
              </span>
              <p class="text-[14.5px] font-semibold leading-snug text-slow-ink">{c}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
