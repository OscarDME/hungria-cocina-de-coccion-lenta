---
// Doc §12: implementación exacta del Pixel con deduplicación de PageView.
// El PIXEL_ID se cambia directamente acá; NO va en copy.js.
const PIXEL_ID = '1357041349597963';
---

<!-- Meta Pixel — snippet oficial + dedupe (doc §12) -->
<script is:inline define:vars={{ PIXEL_ID }}>
  !(function (f, b, e, v, n, t, s) {
    if (f.fbq) return;
    n = f.fbq = function () {
      n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
    };
    if (!f._fbq) f._fbq = n;
    n.push = n;
    n.loaded = !0;
    n.version = '2.0';
    n.queue = [];
    t = b.createElement(e);
    t.async = !0;
    t.src = v;
    s = b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t, s);
  })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');

  fbq('set', 'autoConfig', false, PIXEL_ID);
  fbq('init', PIXEL_ID, {}, { disablePushState: true });
  fbq('track', 'PageView');
</script>

<script is:inline>
  // Dedupe: evita PageViews duplicados (doc §12 Bloque 2)
  (function () {
    if (!window.fbq) return;
    let lastPVUrl = location.href;
    const origCallMethod = window.fbq.callMethod;
    window.fbq.callMethod = function () {
      const args = Array.prototype.slice.call(arguments);
      if (args[0] === 'track' && args[1] === 'PageView') {
        if (lastPVUrl === location.href && window.__pvSent) return;
        lastPVUrl = location.href;
        window.__pvSent = true;
      }
      return origCallMethod && origCallMethod.apply(this, args);
    };
  })();
</script>

<noscript>
  <img
    height="1"
    width="1"
    style="display:none"
    src={`https://www.facebook.com/tr?id=${PIXEL_ID}&ev=PageView&noscript=1`}
    alt=""
  />
</noscript>
