---
// Aparición suave al hacer scroll para .reveal (doc §8: JS vanilla, 0 KB de
// framework). No renderiza marcado; solo instala un IntersectionObserver.
---
<script>
  (function () {
    const els = document.querySelectorAll('.reveal');
    if (!els.length) return;
    // Activa el estado inicial oculto SOLO ahora que sabemos que el JS corre.
    document.documentElement.classList.add('js-anim');
    if (!('IntersectionObserver' in window) || matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );
    els.forEach((el) => io.observe(el));

    // Failsafe de resiliencia: si el IntersectionObserver nunca marca nada
    // (viewport atípico / entorno sin IO real), revela todo para no dejar
    // contenido oculto. Si el observer sí funciona, para entonces ya habrá
    // elementos visibles y no se fuerza nada (se respeta la animación al scroll).
    setTimeout(() => {
      if (!document.querySelector('.reveal.is-visible')) {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    }, 1200);
  })();
</script>
